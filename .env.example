# LLM provider 선택: auto | gemini | anthropic | mock  (auto=가진 키 우선순위로 자동 선택)
OHN_PROVIDER=auto

# Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx
# Anthropic 모델 (일 배치라 비용/속도 균형상 sonnet 권장)
OHN_MODEL=claude-sonnet-4-6

# Google Gemini API (GEMINI_API_KEY 또는 GOOGLE_API_KEY 둘 중 하나)
GEMINI_API_KEY=AIza-xxxxx
OHN_GEMINI_MODEL=gemini-2.5-flash

# Supabase (운영 DB). 없으면 인메모리 store로 동작
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGci...service_role_or_anon...

# CORS 허용 출처(콤마 구분). 운영은 프론트 출처로 좁힐 것. 기본 *
OHN_CORS_ORIGINS=https://timeleeh.github.io

# 카카오 공유
OHN_KAKAO_JS_KEY=카카오_JavaScript_키
OHN_APP_URL=https://timeleeh.github.io/ohun/
# 공유 카드 한글 폰트(서버에 글꼴 필요). Docker는 fonts-nanum 자동, 직접 띄울 땐 경로 지정
# OHN_CARD_FONT=/usr/share/fonts/truetype/nanum/NanumGothic.ttf
# OHN_CARD_FONT_BOLD=/usr/share/fonts/truetype/nanum/NanumGothicBold.ttf

# 위트/다양성 확보용 temperature
OHN_TEMPERATURE=0.95
# 그룹 최대 인원 (기획 확정값)
OHN_MAX_GROUP_SIZE=6
# LLM에 전달할 케미 페어 상위 개수 (상생/상극 드라마 강한 순)
OHN_MAX_PAIRS=6
